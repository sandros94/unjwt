{
  "name": "unjwt",
  "version": "0.7.0",
  "description": "Low-level JWT utilities",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandros94/unjwt.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./jwk": {
      "types": "./dist/core/jwk.d.mts",
      "default": "./dist/core/jwk.mjs"
    },
    "./jws": {
      "types": "./dist/core/jws.d.mts",
      "default": "./dist/core/jws.mjs"
    },
    "./jwe": {
      "types": "./dist/core/jwe.d.mts",
      "default": "./dist/core/jwe.mjs"
    },
    "./utils": {
      "types": "./dist/core/utils/index.d.mts",
      "default": "./dist/core/utils/index.mjs"
    },
    "./adapters/h3": {
      "types": "./dist/adapters/h3v1/index.d.mts",
      "default": "./dist/adapters/h3v1/index.mjs"
    },
    "./adapters/h3v1": {
      "types": "./dist/adapters/h3v1/index.d.mts",
      "default": "./dist/adapters/h3v1/index.mjs"
    },
    "./adapters/h3v2": {
      "types": "./dist/adapters/h3v2/index.d.mts",
      "default": "./dist/adapters/h3v2/index.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "bun --watch ./playground/main.ts",
    "dev:prepare": "obuild --stub && pnpm simple-git-hooks",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "automd && oxlint --fix . && oxfmt .",
    "prepack": "pnpm build",
    "release": "pnpm test && pnpm prepack && changelogen --release --push",
    "stub": "obuild --stub",
    "test": "vitest run --slowTestThreshold=1000",
    "test:coverage": "vitest run --coverage --slowTestThreshold=1000",
    "typecheck": "tsgo --noEmit",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/supertest": "^7.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "@vitest/coverage-v8": "^4.1.4",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "cookie-esv1": "npm:cookie-es@^1.2.3",
    "cookie-esv3": "npm:cookie-es@^3.1.1",
    "h3v1": "npm:h3@^1.15.11",
    "h3v2": "npm:h3@^2.0.1-rc.20",
    "jose": "^6.2.2",
    "nano-staged": "^1.0.2",
    "obuild": "^0.4.33",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "rolldown": "1.0.0-rc.16",
    "rou3": "^0.8.1",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unsecure": "^0.2.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "cookie-es": "^1.2.3 || ^3.1.1",
    "h3": "^1.15.4 || >=2.0.1-rc.20 || ^2.0.1"
  },
  "peerDependenciesMeta": {
    "cookie-es": {
      "optional": true
    },
    "h3": {
      "optional": true
    }
  },
  "resolutions": {
    "unjwt": "link:."
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,yml,md}": [
      "pnpm run fmt"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
